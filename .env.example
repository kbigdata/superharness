# superharness 환경변수 (모두 선택). 기본값은 오프라인(mock)으로 동작한다.

# 프로바이더: mock(기본, 오프라인) | anthropic
SUPERHARNESS_PROVIDER=mock

# 중앙 상태 디렉토리
SUPERHARNESS_STATE_DIR=./.superharness

# 멀티프로젝트 격리(선택): STATE_ROOT 설정 시 effective 상태 경로 = {STATE_ROOT}/{PROJECT_ID}.
# PROJECT_ID 미설정 시 현재 작업 경로 해시로 자동 파생. STATE_ROOT 미설정이면 위 STATE_DIR 그대로.
# SUPERHARNESS_STATE_ROOT=~/.superharness/projects
# SUPERHARNESS_PROJECT_ID=my-project

# 병렬 에이전트 실행 on/off, 동시성 상한
SUPERHARNESS_PARALLEL_EXECUTION=true
SUPERHARNESS_MAX_CONCURRENCY=4

# Ralph/fix 루프 최대 반복
SUPERHARNESS_MAX_ITERATIONS=10

# 티어→모델 override (claude-api 레퍼런스 기준 기본값)
SUPERHARNESS_TIER_LOW=claude-haiku-4-5
SUPERHARNESS_TIER_MEDIUM=claude-sonnet-4-6
SUPERHARNESS_TIER_HIGH=claude-opus-4-8

# 로그 레벨
SUPERHARNESS_LOG=INFO

# anthropic 프로바이더 사용 시에만 필요
# ANTHROPIC_API_KEY=sk-ant-...
